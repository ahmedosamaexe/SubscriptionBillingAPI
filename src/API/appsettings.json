{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=SubscriptionBillingDB;Username=postgres;Password=your_password_here"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-jwt-key-min-32-characters-long!",
    "Issuer": "SubscriptionBillingAPI",
    "Audience": "SubscriptionBillingAPI",
    "ExpirationHours": "24"
  },
  "StripeSettings": {
    "SecretKey": "sk_test_your_stripe_secret_key_here",
    "PublishableKey": "pk_test_your_stripe_publishable_key_here",
    "WebhookSecret": "whsec_your_stripe_webhook_secret_here",
    "SuccessUrl": "https://localhost:7001/success?session_id={CHECKOUT_SESSION_ID}",
    "CancelUrl": "https://localhost:7001/cancel"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
